{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "County Lead Intelligence Engine - County Config",
  "type": "object",
  "required": [
    "county_id",
    "county_name",
    "state",
    "geography",
    "sources",
    "dashboard",
    "deployment"
  ],
  "additionalProperties": false,
  "properties": {
    "county_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]+$",
      "description": "Short lowercase identifier used in URLs and filenames"
    },
    "county_name": {
      "type": "string",
      "minLength": 1
    },
    "state": {
      "type": "string",
      "pattern": "^[A-Z]{2}$",
      "description": "Two-letter state code"
    },
    "subject_state_full": {
      "type": "string"
    },
    "fips_code": {
      "type": "string",
      "pattern": "^[0-9]{5}$"
    },
    "timezone": {
      "type": "string"
    },
    "operator_market_priority": {
      "type": "string",
      "enum": [
        "primary",
        "secondary",
        "exploratory"
      ]
    },
    "state_rule_family": {
      "type": "string",
      "description": "v5.1.2-beta+: Identifies the state legal framework this county operates under. Translators and matchers use this to look up state-level defaults (statute references, foreclosure-stage doc-types, recording conventions) without hardcoding state-specific logic in scaffold/pipeline/. Counties in the same state share a rule family. If a county needs to override the state family's defaults, the override goes in geography.* or sources.*. If omitted, the framework operates with no state-level assumptions (all rules must be specified explicitly per county).",
      "enum": [
        "TX_non_judicial_foreclosure",
        "CA_non_judicial_foreclosure",
        "AZ_non_judicial_foreclosure",
        "GA_non_judicial_foreclosure",
        "FL_judicial_foreclosure",
        "NY_judicial_foreclosure",
        "NJ_judicial_foreclosure",
        "OH_judicial_foreclosure",
        "PA_judicial_foreclosure",
        "IL_judicial_foreclosure",
        ""
      ]
    },
    "geography": {
      "type": "object",
      "required": [
        "municipalities",
        "parcel_id_format"
      ],
      "properties": {
        "municipalities": {
          "type": "array",
          "description": "Canonical list of incorporated municipalities in this county. Used for dashboard filters, location parsers, and validation. Distinct from accepted_municipalities[] which is a superset including unincorporated communities + spelling variants.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "code"
            ],
            "properties": {
              "name": {
                "type": "string"
              },
              "code": {
                "type": "string"
              },
              "fips_place": {
                "type": "string"
              }
            }
          }
        },
        "accepted_municipalities": {
          "type": "array",
          "description": "v5.1.2-beta+: Superset of municipalities[] including unincorporated communities, CDP designations, and spelling variants known to be in-county. Used by source translators to gate the potential_cross_county_leak review flag \u2014 addresses whose city is NOT in this list get flagged for operator review. Each entry has a `name` (uppercase canonical) and a `kind` describing why it's accepted. If omitted, cross-county detection falls back to municipalities[] only.",
          "items": {
            "type": "object",
            "required": [
              "name",
              "kind"
            ],
            "properties": {
              "name": {
                "type": "string",
                "description": "Uppercase canonical name. Translators compare addresses against this exact string (case-insensitive)."
              },
              "kind": {
                "type": "string",
                "enum": [
                  "incorporated",
                  "unincorporated_community",
                  "cdp",
                  "spelling_variant",
                  "neighboring_overlap"
                ],
                "description": "Why this name is accepted. `neighboring_overlap` flags cities that border the county and may legitimately appear in records (handled at translator level, NOT a cross-county leak)."
              },
              "canonical_name": {
                "type": "string",
                "description": "Optional. If this entry is a spelling_variant or CDP, what its canonical municipality name is."
              }
            }
          }
        },
        "cross_county_policy": {
          "type": "object",
          "description": "v5.1.2-beta+: How translators should handle addresses whose city is not in accepted_municipalities[]. Controls whether the lead is dropped, flagged for review, or accepted with a warning.",
          "properties": {
            "unknown_city_action": {
              "type": "string",
              "enum": [
                "drop",
                "flag_for_review",
                "accept_with_warning"
              ],
              "default": "flag_for_review",
              "description": "What to do with leads from a city not in accepted_municipalities[]. `flag_for_review` is recommended (sets review_flag=potential_cross_county_leak). `drop` discards the lead. `accept_with_warning` writes a note but still ships the lead."
            },
            "neighboring_county_municipalities": {
              "type": "array",
              "description": "Optional list of municipality names known to overlap the county boundary. Useful for operator review notes.",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "sale_date_rule": {
          "type": "object",
          "description": "v5.1.2-beta+: How translators should derive `expected_sale_date` for foreclosure / sheriff sale leads when the raw source only provides year+month. Captures state statute. The framework provides a registry of rule implementations; counties pick by `rule_name`. If omitted, translators use first-of-month as a fallback.",
          "properties": {
            "rule_name": {
              "type": "string",
              "enum": [
                "first_tuesday_of_month",
                "first_monday_of_month",
                "first_business_day_of_month",
                "any_business_day_after_notice",
                "scheduled_by_sheriff",
                "scheduled_by_court",
                "custom"
              ],
              "description": "Registered rule name. Framework dispatches to the matching implementation."
            },
            "holiday_shift": {
              "type": "object",
              "description": "Optional. How to shift sale dates that fall on a state-recognized holiday.",
              "properties": {
                "shift_dates": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^[0-9]{2}-[0-9]{2}$",
                    "description": "MM-DD format. E.g. '01-01' for New Year's Day, '07-04' for Independence Day."
                  }
                },
                "shift_to": {
                  "type": "string",
                  "enum": [
                    "next_weekday",
                    "next_wednesday",
                    "next_tuesday",
                    "next_business_day",
                    "previous_business_day"
                  ]
                }
              }
            },
            "statute_reference": {
              "type": "string",
              "description": "Plain-text citation. Used in operator notes and dashboard explanations."
            }
          }
        },
        "parcel_id_format": {
          "type": "string"
        },
        "parcel_id_normalization": {
          "type": "string"
        },
        "address_format_notes": {
          "type": "string"
        }
      }
    },
    "sources": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "category",
          "subtype",
          "access_pattern",
          "scraper_module",
          "refresh_cadence"
        ],
        "properties": {
          "category": {
            "type": "string",
            "enum": [
              "lead",
              "enrichment"
            ]
          },
          "subtype": {
            "type": "string",
            "enum": [
              "clerk_recordings",
              "court_civil",
              "court_probate",
              "court_family",
              "court_eviction",
              "sheriff_sales",
              "tax_delinquency",
              "tax_certificates",
              "code_enforcement",
              "parcel_master",
              "gis_parcels",
              "usps_vacancy",
              "utility_shutoff"
            ]
          },
          "url": {
            "type": "string"
          },
          "access_pattern": {
            "type": "string",
            "enum": [
              "open_api",
              "static_html",
              "spa_with_api",
              "spa_recaptcha",
              "waf_imperva",
              "paywall",
              "saml",
              "sealed",
              "public_records_only"
            ]
          },
          "auth_required": {
            "type": "boolean"
          },
          "rate_limit_rpm": {
            "type": [
              "integer",
              "null"
            ]
          },
          "scraper_module": {
            "type": "string"
          },
          "translator": {
            "type": "string",
            "description": "v5.1.2-beta+: Name of a registered translator function in scaffold/pipeline/translators/. Tells the orchestrator how to convert this source's raw records into framework signals + placeholder parcels. If empty, the orchestrator skips this source during pipeline run (raw data still gets pulled but does not produce signals). Examples: 'foreclosure_notices', 'parcel_master', 'publicsearch_clerk_recordings', 'tyler_odyssey_court', 'csv_static_list'. Renamed in v5.1.2-beta-r2: arcgis_foreclosure_notices -> foreclosure_notices, arcgis_parcel_master -> parcel_master (translators are now protocol-agnostic; portal protocol lives in the scraper).",
            "enum": [
              "",
              "foreclosure_notices",
              "parcel_master",
              "publicsearch_clerk_recordings",
              "tyler_odyssey_court",
              "csv_static_list",
              "static_html_table",
              "tax_deed_auction_listing",
              "custom"
            ]
          },
          "translator_config": {
            "type": "object",
            "description": "v5.1.2-beta+: Per-translator configuration. Schema is translator-specific; the translator validates its own config at registration time. Examples: layer_doc_type_map for foreclosure_notices, field_label_aliases for publicsearch_clerk_recordings."
          },
          "field_map": {
            "type": "object",
            "description": "v5.1.2-beta+: Maps the source's raw field names to framework-canonical field names. Replaces hardcoded source-specific field name references in pipeline code. Example for an appraisal-district parcel source: {\"parcel_id\": \"<source's parcel ID field>\", \"situs_address\": \"<source's situs field>\", \"owner_name\": \"<source's owner field>\", \"exemptions\": \"<source's exemptions field>\"}. Keys are framework-canonical field names; values are the source's actual field names.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "parcel_id_prefix": {
            "type": "string",
            "description": "v5.1.2-beta+: Prefix used to construct synthetic parcel IDs when this source produces records that aren't yet matched to a real parcel-master entry. Replaces hardcoded prefixes in pipeline code. Should be SHORT and county-mnemonic. If omitted, framework uses a generic 'PARCEL-' prefix.",
            "pattern": "^[A-Z][A-Z0-9_-]{0,15}-?$"
          },
          "fields": {
            "type": "object"
          },
          "doc_type_synonyms": {
            "type": "object",
            "description": "v5.1.2-beta+: Maps source-specific document type strings to framework-canonical doc type names. Replaces hardcoded source aliases in scaffold/pipeline/normalize.py. Keys are the source's literal doc-type strings (case-insensitive lookup at runtime); values are canonical type names from knowledge_base/domain/canonical_doc_types.json. Example: {\"Notice of Substitute Trustee's Sale\": \"NOTICE_OF_SUBSTITUTE_TRUSTEE_SALE\", \"NSTS\": \"NOTICE_OF_SUBSTITUTE_TRUSTEE_SALE\"}.",
            "additionalProperties": {
              "type": "string"
            }
          },
          "refresh_cadence": {
            "type": "string",
            "enum": [
              "daily",
              "weekly",
              "monthly",
              "quarterly",
              "on_demand"
            ]
          },
          "ttl_days": {
            "type": "integer",
            "minimum": 1
          },
          "blocked_unblock_paths": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "public_records",
                "seeded_session",
                "captcha_solver",
                "stealth_browser",
                "manual_pull",
                "residential_proxy",
                "operator_login"
              ]
            }
          },
          "notes": {
            "type": "string"
          },
          "source_reliability_grade": {
            "type": "string",
            "enum": [
              "A",
              "B",
              "C",
              "D",
              "E",
              ""
            ]
          },
          "source_freshness": {
            "type": "string"
          },
          "known_limitations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "last_verified_at": {
            "type": "string"
          },
          "source_priority": {
            "type": "string",
            "enum": [
              "P0",
              "P1",
              "P2",
              ""
            ]
          },
          "build_priority": {
            "type": "string",
            "enum": [
              "mvp_required",
              "high_value",
              "enrichment",
              "optional",
              "future",
              ""
            ]
          },
          "enabled": {
            "type": "boolean"
          },
          "paused_reason": {
            "type": "string"
          },
          "pause_until": {
            "type": "string"
          },
          "allowed_to_export": {
            "type": "boolean"
          },
          "official_status": {
            "type": "string",
            "enum": [
              "OFFICIAL",
              "OFFICIAL_COUNTY",
              "OFFICIAL_STATE",
              "OFFICIAL_CITY",
              "OFFICIAL_COURT",
              "OFFICIAL_VENDOR_PORTAL",
              "UNVERIFIED",
              "NOT_FOUND",
              ""
            ],
            "description": "How the source's official status was determined. v5.0.0 introduces the 5-way OFFICIAL_* split; 'OFFICIAL' is retained for backward compatibility but new builds should use the granular values."
          },
          "lead_value": {
            "type": "string",
            "enum": [
              "LEAD_GENERATING",
              "ENRICHMENT",
              "REFERENCE_ONLY",
              "UNKNOWN",
              ""
            ]
          },
          "operator_override": {
            "type": "boolean",
            "description": "If true, operator has explicitly approved using this source even if verification_confidence is LOW or source_role is BLOCKED_SOURCE. Required for build to proceed past Phase 0 with low-confidence sources."
          },
          "verification_note": {
            "type": "string",
            "description": "Free-text explaining the verification outcome and any caveats."
          },
          "open_questions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Free-text questions the operator must answer before this source can ship."
          },
          "verified_from_url": {
            "type": "string",
            "description": "The official government page (or officially-linked vendor index) from which the source URL was discovered. Required for verification_confidence HIGH or MEDIUM."
          },
          "verification_method": {
            "type": "string",
            "enum": [
              "official_domain",
              "official_page_link",
              "official_vendor_link",
              "state_portal",
              "court_portal",
              "city_portal",
              "manual_operator_verified",
              "not_verified",
              ""
            ]
          },
          "official_entity": {
            "type": "string",
            "description": "Name of the official government entity that owns/operates this source. Example: '<County Name> Clerk's Office' or '<State> Court of Appeals'."
          },
          "portal_type": {
            "type": "string",
            "description": "Free-text describing what this portal is (e.g. 'land records search', 'tax delinquency lookup', 'foreclosure docket search')."
          },
          "records_available": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of record types this source actually exposes (e.g. ['deeds', 'mortgages', 'liens', 'lis_pendens'])."
          },
          "search_fields": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Search fields the portal exposes (e.g. ['name', 'parcel_id', 'date_range', 'document_type'])."
          },
          "access_method": {
            "type": "string",
            "enum": [
              "OPEN_PUBLIC_PORTAL",
              "SEARCHABLE_PUBLIC_PORTAL",
              "DOWNLOADABLE_FILE",
              "PDF_PUBLICATION",
              "API_ENDPOINT",
              "MAP_LAYER",
              "PUBLIC_BUT_CAPTCHA_PROTECTED",
              "PUBLIC_BUT_WAF_PROTECTED",
              "PUBLIC_BUT_SESSION_REQUIRED",
              "FREE_ACCOUNT_REQUIRED",
              "PAID_SUBSCRIPTION_REQUIRED",
              "LOGIN_REQUIRED",
              "OPERATOR_CREDENTIAL_REQUIRED",
              "REQUEST_ONLY",
              "MANUAL_PUBLIC_RECORDS_DELIVERY",
              "NOT_SEARCHABLE",
              "UNKNOWN",
              ""
            ]
          },
          "public_access_status": {
            "type": "string",
            "enum": [
              "FULL_PUBLIC_ACCESS",
              "PUBLIC_SEARCH_ONLY",
              "PUBLIC_SEARCH_DOCUMENTS_LOCKED",
              "FREE_ACCOUNT_REQUIRED",
              "PAID_SUBSCRIPTION_REQUIRED",
              "LOGIN_REQUIRED",
              "CLERK_APPROVAL_REQUIRED",
              "CAPTCHA_PROTECTED",
              "WAF_PROTECTED",
              "REQUEST_ONLY",
              "BLOCKED",
              "UNKNOWN",
              ""
            ]
          },
          "document_access_status": {
            "type": "string",
            "enum": [
              "DOCUMENTS_PUBLIC",
              "DOCUMENTS_PUBLIC_WITH_CAPTCHA",
              "DOCUMENTS_LOGIN_REQUIRED",
              "DOCUMENTS_PAID_SUBSCRIPTION_REQUIRED",
              "DOCUMENTS_CLERK_APPROVAL_REQUIRED",
              "DOCUMENTS_NOT_AVAILABLE",
              "DOCUMENTS_UNKNOWN",
              ""
            ]
          },
          "source_role": {
            "type": "string",
            "enum": [
              "PRIMARY_LEAD_SOURCE",
              "SUPPORTING_LEAD_SOURCE",
              "ENRICHMENT_SOURCE",
              "REFERENCE_ONLY",
              "BLOCKED_SOURCE",
              "NOT_FOUND",
              ""
            ]
          },
          "verification_confidence": {
            "type": "string",
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW",
              "BLOCKED",
              "NOT_FOUND",
              ""
            ]
          },
          "sample_record_path_confirmed": {
            "type": "boolean",
            "description": "True if Claude Code has confirmed the path to records exists on this portal (does NOT mean a record was scraped, just that the search/index/list page was located)."
          },
          "sample_record_type": {
            "type": "string",
            "description": "Type of sample record path confirmed (e.g. 'search_form', 'docket_list', 'pdf_index', 'api_endpoint')."
          },
          "sample_search_possible": {
            "type": "boolean",
            "description": "True if a public user can perform a search on this portal without login or payment."
          },
          "sample_document_view_possible": {
            "type": "boolean",
            "description": "True if a public user can view at least one document image / page result on this portal without additional access requirements."
          },
          "blocker": {
            "type": "string",
            "description": "Short description of what's blocking access (empty if not blocked)."
          },
          "next_access_strategy": {
            "type": "string",
            "enum": [
              "try_open_public_portal",
              "find_official_vendor_link",
              "discover_hidden_api",
              "use_playwright",
              "use_seeded_session",
              "use_captcha_solver",
              "use_stealth_browser",
              "use_residential_proxy",
              "use_operator_login",
              "request_free_account",
              "use_paid_subscription_if_operator_provides",
              "manual_operator_assisted_pull",
              "standing_records_delivery",
              "public_records_request_last_resort",
              "not_available",
              ""
            ]
          },
          "blocker_type": {
            "type": "string",
            "enum": [
              "TECHNICAL_BLOCKER",
              "PERMISSION_BLOCKER",
              "SOURCE_NOT_FOUND",
              "SOURCE_AMBIGUOUS",
              "SOURCE_DEAD",
              "SOURCE_WRONG_CATEGORY",
              "SOURCE_ENRICHMENT_ONLY",
              "SOURCE_VERIFIED_BUT_NOT_BUILDABLE",
              "NO_PRIMARY_LEAD_SOURCE",
              "PORTAL_PROOF_MISSING",
              "DOCUMENT_ACCESS_LOCKED",
              "PUBLIC_ACCESS_UNCLEAR",
              "PAID_ACCESS_REQUIRED",
              "OPERATOR_CREDENTIAL_REQUIRED",
              "MANUAL_ASSISTANCE_REQUIRED",
              ""
            ]
          },
          "auto_resolve_status": {
            "type": "string",
            "enum": [
              "NOT_ATTEMPTED",
              "ATTEMPTING",
              "RESOLVED",
              "PARTIALLY_RESOLVED",
              "FAILED",
              "REQUIRES_OPERATOR_APPROVAL",
              "REQUIRES_CREDENTIALS",
              "REQUIRES_PAYMENT",
              "REQUIRES_MANUAL_ASSISTANCE",
              "NOT_ALLOWED",
              ""
            ]
          },
          "final_resolution_status": {
            "type": "string",
            "enum": [
              "RESOLVED",
              "PARTIALLY_RESOLVED",
              "UNRESOLVED_TECHNICAL",
              "UNRESOLVED_PERMISSION",
              "UNRESOLVED_NOT_FOUND",
              "UNRESOLVED_NOT_ALLOWED",
              "OPERATOR_REQUIRED",
              "CREDENTIALS_REQUIRED",
              "PAYMENT_REQUIRED",
              "MANUAL_ASSISTANCE_REQUIRED",
              ""
            ]
          },
          "auto_resolve_attempts": {
            "type": "array",
            "description": "Ordered log of resolution attempts for this source (v5.1.0+).",
            "items": {
              "type": "object",
              "properties": {
                "attempt_order": {
                  "type": "integer",
                  "minimum": 1
                },
                "timestamp": {
                  "type": "string"
                },
                "blocker_type": {
                  "type": "string",
                  "enum": [
                    "TECHNICAL_BLOCKER",
                    "PERMISSION_BLOCKER",
                    "SOURCE_NOT_FOUND",
                    "SOURCE_AMBIGUOUS",
                    "SOURCE_DEAD",
                    "SOURCE_WRONG_CATEGORY",
                    "SOURCE_ENRICHMENT_ONLY",
                    "SOURCE_VERIFIED_BUT_NOT_BUILDABLE",
                    "NO_PRIMARY_LEAD_SOURCE",
                    "PORTAL_PROOF_MISSING",
                    "DOCUMENT_ACCESS_LOCKED",
                    "PUBLIC_ACCESS_UNCLEAR",
                    "PAID_ACCESS_REQUIRED",
                    "OPERATOR_CREDENTIAL_REQUIRED",
                    "MANUAL_ASSISTANCE_REQUIRED",
                    ""
                  ]
                },
                "strategy": {
                  "type": "string",
                  "enum": [
                    "find_official_vendor_link",
                    "replace_homepage_with_record_portal",
                    "discover_public_search_endpoint",
                    "discover_hidden_api",
                    "inspect_network_requests",
                    "use_playwright",
                    "use_session_cookie",
                    "use_seeded_session",
                    "use_captcha_solver",
                    "use_stealth_browser",
                    "use_residential_proxy",
                    "use_operator_login",
                    "request_free_account",
                    "use_paid_subscription_if_operator_provides",
                    "manual_operator_assisted_pull",
                    "standing_records_delivery",
                    "public_records_request_last_resort",
                    "mark_not_available",
                    ""
                  ]
                },
                "status": {
                  "type": "string",
                  "enum": [
                    "PENDING",
                    "SUCCESS",
                    "FAILED",
                    "BLOCKED_BY_PERMISSION",
                    "BLOCKED_BY_COST",
                    "REQUIRES_CREDENTIALS",
                    "REQUIRES_OPERATOR_APPROVAL",
                    "SKIPPED_NOT_ALLOWED",
                    ""
                  ]
                },
                "result": {
                  "type": "string"
                },
                "evidence": {
                  "type": "string"
                },
                "files_created": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "files_modified": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "next_step": {
                  "type": "string"
                }
              },
              "required": [
                "attempt_order",
                "timestamp",
                "strategy",
                "status"
              ]
            }
          },
          "lifecycle_status": {
            "type": "string",
            "enum": [
              "ACTIVE",
              "PENDING",
              "CURED",
              "RELEASED",
              "SATISFIED",
              "CANCELLED",
              "DISMISSED",
              "SOLD",
              "EXPIRED",
              "SUPERSEDED",
              "UNKNOWN",
              ""
            ]
          },
          "suppression_reason": {
            "type": "string",
            "enum": [
              "released",
              "satisfied",
              "paid",
              "cancelled",
              "dismissed",
              "sold",
              "expired",
              "superseded",
              "manual_review",
              "unknown",
              ""
            ]
          },
          "expected_refresh_cadence": {
            "type": "string",
            "enum": [
              "REAL_TIME",
              "DAILY",
              "WEEKLY",
              "MONTHLY",
              "REQUEST_BASED",
              "MANUAL",
              "UNKNOWN",
              ""
            ]
          },
          "source_freshness_status": {
            "type": "string",
            "enum": [
              "FRESH",
              "STALE",
              "OVERDUE",
              "FAILED",
              "PAUSED",
              "UNKNOWN",
              ""
            ]
          },
          "stale_after_hours": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "last_successful_fetch_at": {
            "type": "string"
          },
          "last_attempted_fetch_at": {
            "type": "string"
          },
          "last_record_seen_at": {
            "type": "string"
          },
          "record_ttl_days": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "expire_if_not_seen_runs": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 1
          },
          "stale_record_policy": {
            "type": "string",
            "enum": [
              "KEEP_UNTIL_RELEASED",
              "EXPIRE_IF_NOT_SEEN",
              "EXPIRE_AFTER_TTL",
              "MANUAL_REVIEW",
              "NEVER_EXPIRE",
              ""
            ]
          },
          "quarantine_status": {
            "type": "string",
            "enum": [
              "NOT_QUARANTINED",
              "QUARANTINED",
              "UNDER_REVIEW",
              "RELEASED",
              ""
            ]
          },
          "quarantine_reason": {
            "type": "string"
          },
          "estimated_runtime_minutes": {
            "type": [
              "integer",
              "null"
            ],
            "minimum": 0
          },
          "estimated_cost_category": {
            "type": "string",
            "enum": [
              "FREE",
              "LOW",
              "MEDIUM",
              "HIGH",
              "UNKNOWN",
              "REQUIRES_OPERATOR_APPROVAL",
              ""
            ]
          },
          "portal_fingerprint_id": {
            "type": "string"
          },
          "portal_family": {
            "type": "string",
            "description": "Vendor family (Tyler, Aumentum, GovOS, Kofile, Fidlar, RealAuction, ArcGIS, etc.) or 'custom_county'."
          },
          "fingerprinted_at": {
            "type": "string"
          },
          "fingerprint_confidence": {
            "type": "string",
            "enum": [
              "HIGH",
              "MEDIUM",
              "LOW",
              ""
            ]
          },
          "fingerprint_summary": {
            "type": "string"
          },
          "recommended_adapter": {
            "type": "string"
          },
          "credentials_required_kind": {
            "type": "string",
            "enum": [
              "",
              "free_account",
              "paid_subscription",
              "operator_login",
              "clerk_approved_login",
              "identity_verified_account",
              "captcha_solver_key",
              "proxy_credentials",
              "api_key"
            ]
          },
          "credentials_declared": {
            "type": "boolean"
          },
          "manual_upload_path": {
            "type": "string"
          },
          "manual_upload_received_at": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "official_status": {
                  "enum": [
                    "UNVERIFIED",
                    "NOT_FOUND"
                  ]
                }
              },
              "required": [
                "official_status"
              ]
            },
            "then": {
              "properties": {
                "operator_override": {
                  "const": true
                }
              },
              "required": [
                "operator_override"
              ]
            },
            "$comment": "If official_status is UNVERIFIED or NOT_FOUND, operator_override must be true before this source can be built. Per MASTER_PROMPT.md Phase 0 hard rules."
          }
        ]
      }
    },
    "scoring_overrides": {
      "type": "object",
      "properties": {
        "match_confidence_floor": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "review_queue_ratio_alert_threshold": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "high_equity_assessed_to_sale_ratio": {
          "type": "number",
          "minimum": 1.0
        },
        "long_term_owned_years": {
          "type": "integer",
          "minimum": 1
        },
        "senior_owner_proxy_years": {
          "type": "integer",
          "minimum": 1
        },
        "favorable_loan_era_start": {
          "type": "string",
          "format": "date"
        },
        "favorable_loan_era_end": {
          "type": "string",
          "format": "date"
        }
      }
    },
    "storage": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "STATIC_JSON_MODE",
            "SUPABASE_MODE",
            "HYBRID_MODE"
          ]
        },
        "supabase_enabled": {
          "type": "boolean"
        },
        "dashboard_payload": {
          "type": "string"
        },
        "retain_raw_records_days": {
          "type": "integer",
          "minimum": 1
        },
        "retain_source_runs_days": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "dashboard": {
      "type": "object",
      "required": [
        "title",
        "primary_color",
        "accent_color"
      ],
      "properties": {
        "title": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "primary_color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "accent_color": {
          "type": "string",
          "pattern": "^#[0-9A-Fa-f]{6}$"
        },
        "default_view": {
          "type": "string"
        },
        "precanned_views": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id",
              "label",
              "filter"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "filter": {
                "type": "string"
              }
            }
          }
        },
        "view_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "CLIENT_VIEW",
              "OPERATOR_VIEW",
              "DEMO_VIEW",
              "PAUSED_VIEW",
              "REDACTED_VIEW"
            ]
          }
        },
        "build_label": {
          "type": "string",
          "enum": [
            "FULL_BUILD",
            "PARTIAL_BUILD",
            "SOURCE_LIMITED",
            "PRIMARY_SOURCE_PENDING",
            ""
          ]
        },
        "build_label_reason": {
          "type": "string"
        }
      }
    },
    "deployment": {
      "type": "object",
      "required": [
        "github_org",
        "github_repo"
      ],
      "properties": {
        "github_org": {
          "type": "string"
        },
        "github_repo": {
          "type": "string"
        },
        "live_url": {
          "type": "string"
        },
        "scheduled_task_name": {
          "type": "string"
        },
        "watchdog_task_name": {
          "type": "string"
        },
        "scheduler_runtime_class": {
          "type": "string",
          "enum": [
            "RUNS_WHEN_LOGGED_IN_ONLY",
            "RUNS_WHEN_LOCKED",
            "RUNS_ON_GITHUB_ACTIONS",
            "RUNS_ON_SERVER",
            "SCHEDULER_NOT_CONFIGURED",
            "SCHEDULER_REQUIRES_OPERATOR_CREDENTIALS",
            ""
          ]
        },
        "scheduler_test_fired_at": {
          "type": "string"
        },
        "production_verification_status": {
          "type": "string",
          "enum": [
            "NOT_RUN",
            "PASSED",
            "FAILED",
            "PRODUCTION_VERIFICATION_BLOCKED",
            ""
          ]
        },
        "production_verification_at": {
          "type": "string"
        },
        "last_known_good_commit": {
          "type": "string"
        },
        "last_known_good_dashboard_at": {
          "type": "string"
        }
      }
    },
    "build_verdict": {
      "type": "string",
      "enum": [
        "READY_TO_BUILD",
        "READY_WITH_BLOCKERS",
        "RECON_ONLY",
        "WAITING_ON_ACCESS",
        "NOT_BUILDABLE_YET",
        "AUTO_RESOLVED_READY_TO_BUILD",
        "PARTIALLY_RESOLVED_BUILDABLE",
        "AUTO_RESOLVE_FAILED",
        ""
      ],
      "description": "Phase 0/0.5 verdict on county build eligibility (v5.0.0 baseline, v5.1.0 adds auto-resolve verdicts)."
    },
    "build_verdict_reason": {
      "type": "string",
      "description": "Plain-English explanation of the build_verdict produced by Phase 0. Required when build_verdict is set."
    },
    "build_verdict_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of when Phase 0 produced build_verdict."
    },
    "auto_resolve_status": {
      "type": "string",
      "enum": [
        "NOT_ATTEMPTED",
        "ATTEMPTING",
        "RESOLVED",
        "PARTIALLY_RESOLVED",
        "FAILED",
        "REQUIRES_OPERATOR_APPROVAL",
        "REQUIRES_CREDENTIALS",
        "REQUIRES_PAYMENT",
        "REQUIRES_MANUAL_ASSISTANCE",
        "NOT_ALLOWED",
        ""
      ],
      "description": "Overall county-level auto-resolve outcome from Phase 0.5 (v5.1.0+)."
    },
    "final_resolution_status": {
      "type": "string",
      "enum": [
        "RESOLVED",
        "PARTIALLY_RESOLVED",
        "UNRESOLVED_TECHNICAL",
        "UNRESOLVED_PERMISSION",
        "UNRESOLVED_NOT_FOUND",
        "UNRESOLVED_NOT_ALLOWED",
        "OPERATOR_REQUIRED",
        "CREDENTIALS_REQUIRED",
        "PAYMENT_REQUIRED",
        "MANUAL_ASSISTANCE_REQUIRED",
        ""
      ]
    },
    "operator_override_audit": {
      "type": "array",
      "description": "Audit trail of operator overrides applied during recon/build (v5.1.0+).",
      "items": {
        "type": "object",
        "properties": {
          "override_id": {
            "type": "string"
          },
          "operator_name": {
            "type": "string"
          },
          "timestamp": {
            "type": "string"
          },
          "source_id": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "risk": {
            "type": "string"
          },
          "what_was_allowed": {
            "type": "string"
          },
          "what_remains_blocked": {
            "type": "string"
          },
          "dashboard_label_required": {
            "type": "string"
          }
        }
      }
    },
    "source_of_record_matrix": {
      "description": "v5.3.0 \u2014 recon Source-of-Record Matrix (null until recon runs).",
      "anyOf": [
        {
          "$ref": "#/$defs/sourceOfRecordMatrix"
        },
        {
          "type": "null"
        }
      ]
    },
    "source_coverage_map": {
      "description": "v5.3.0 \u2014 recon source coverage summary (null until recon runs).",
      "anyOf": [
        {
          "$ref": "#/$defs/sourceCoverageMap"
        },
        {
          "type": "null"
        }
      ]
    },
    "api_discovery": {
      "description": "v5.3.0 \u2014 documented-API discovery report (null until recon runs).",
      "anyOf": [
        {
          "$ref": "#/$defs/apiDiscoveryReport"
        },
        {
          "type": "null"
        }
      ]
    },
    "enrichment_index_strategy": {
      "description": "v5.3.0 \u2014 enrichment index strategy (null until recon runs).",
      "anyOf": [
        {
          "$ref": "#/$defs/enrichmentIndexStrategy"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "candidateSource": {
      "type": "object",
      "description": "A single source investigated for a lead type during recon.",
      "required": [
        "source_id",
        "official_url",
        "authority_type",
        "source_role",
        "access_status",
        "verification_layers"
      ],
      "properties": {
        "source_id": {
          "type": "string"
        },
        "official_url": {
          "type": "string"
        },
        "authority_type": {
          "type": "string"
        },
        "vendor_name": {
          "type": "string"
        },
        "source_role": {
          "type": "string",
          "enum": [
            "PRIMARY_EVENT_SOURCE",
            "SUPPORTING_EVENT_SOURCE",
            "ENRICHMENT_SOURCE",
            "REFERENCE_SOURCE",
            "BLOCKED_SOURCE"
          ]
        },
        "access_status": {
          "type": "string",
          "enum": [
            "OPEN_PUBLIC",
            "SEARCH_ONLY_PUBLIC",
            "FREE_ACCOUNT_REQUIRED",
            "PAID_SUBSCRIPTION_REQUIRED",
            "LOGIN_REQUIRED",
            "CAPTCHA_PROTECTED",
            "DOCUMENT_IMAGES_LOCKED",
            "BLOCKED",
            "UNKNOWN"
          ]
        },
        "bulk_availability": {
          "type": "string",
          "enum": [
            "FULL_COUNTY_BULK",
            "BATCH_QUERY",
            "PER_RECORD_ONLY",
            "UNKNOWN"
          ]
        },
        "verification_layers": {
          "type": "object",
          "description": "Five-layer verification status, one string per layer.",
          "required": [
            "authority",
            "lead_type_relevance",
            "access",
            "extractability",
            "refresh_provenance"
          ],
          "properties": {
            "authority": {
              "type": "string"
            },
            "lead_type_relevance": {
              "type": "string"
            },
            "access": {
              "type": "string"
            },
            "extractability": {
              "type": "string"
            },
            "refresh_provenance": {
              "type": "string"
            }
          }
        },
        "sample_record_path_confirmed": {
          "type": "boolean"
        },
        "sample_document_view_possible": {
          "type": "boolean"
        },
        "minimum_lead_fields_available": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operator_verified": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "leadTypeEntry": {
      "type": "object",
      "description": "Recon result for one canonical lead type in this county.",
      "required": [
        "lead_type",
        "expected_authorities",
        "candidate_sources",
        "selected_source_id",
        "status"
      ],
      "properties": {
        "lead_type": {
          "type": "string"
        },
        "state_applicability": {
          "type": "string",
          "enum": [
            "APPLICABLE",
            "NOT_APPLICABLE_IN_STATE",
            "UNKNOWN"
          ]
        },
        "expected_authorities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidate_sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/candidateSource"
          }
        },
        "selected_source_id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "LIVE_SOURCE_FOUND",
            "LIVE_SOURCE_FOUND_LIMITED_COVERAGE",
            "SOURCE_FOUND_BLOCKED",
            "SOURCE_FOUND_NEEDS_LOGIN",
            "SOURCE_FOUND_PAID",
            "SOURCE_FOUND_CAPTCHA",
            "SOURCE_NOT_FOUND",
            "NOT_APPLICABLE_IN_STATE",
            "NEEDS_OPERATOR_REVIEW",
            "ENRICHMENT_ONLY"
          ]
        },
        "coverage_notes": {
          "type": "string"
        }
      }
    },
    "sourceOfRecordMatrix": {
      "type": "object",
      "description": "Recon Source-of-Record Matrix \u2014 maps each lead type to its official source for this county (see knowledge_base/architecture/16_source_of_record_matrix.md).",
      "required": [
        "county_slug",
        "county_name",
        "state",
        "framework_version",
        "generated_at",
        "lead_types"
      ],
      "properties": {
        "county_slug": {
          "type": "string"
        },
        "county_name": {
          "type": "string"
        },
        "state": {
          "type": "string"
        },
        "framework_version": {
          "type": "string"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "county_build_status": {
          "type": "string",
          "enum": [
            "READY_TO_BUILD",
            "PARTIAL_BUILD_READY",
            "RECON_ONLY",
            "WAITING_ON_ACCESS",
            "NOT_BUILDABLE_YET"
          ]
        },
        "lead_types": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/leadTypeEntry"
          }
        }
      }
    },
    "sourceCoverageMap": {
      "type": "object",
      "description": "Summary of recon coverage \u2014 live, blocked, limited, not-found, and operator-review sources/lead types.",
      "properties": {
        "live_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocked_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limited_coverage_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "not_found_lead_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "operator_review_required": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "discoveredAPI": {
      "type": "object",
      "description": "A documented API discovered during recon.",
      "properties": {
        "api_url": {
          "type": "string"
        },
        "api_type": {
          "type": "string",
          "enum": [
            "REST",
            "GraphQL",
            "SOAP",
            "OData",
            "ArcGIS",
            "Postman_Collection",
            "Swagger_OpenAPI",
            "Other",
            "Unknown"
          ]
        },
        "documentation_url": {
          "type": "string"
        },
        "auth_required": {
          "type": "boolean"
        },
        "rate_limited": {
          "type": "boolean"
        },
        "source_role": {
          "type": "string",
          "enum": [
            "PRIMARY_EVENT_SOURCE",
            "SUPPORTING_EVENT_SOURCE",
            "ENRICHMENT_SOURCE",
            "REFERENCE_SOURCE",
            "BLOCKED_SOURCE"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "apiDiscoveryReport": {
      "type": "object",
      "description": "Documented-API discovery search log and findings.",
      "required": [
        "searched",
        "found"
      ],
      "properties": {
        "searched": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "found": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/discoveredAPI"
          }
        },
        "search_notes": {
          "type": "string"
        }
      }
    },
    "enrichmentIndexStrategy": {
      "type": "object",
      "description": "Strategy for resolving the enrichment index \u2014 bulk vs per-record query.",
      "properties": {
        "bulk_index_available": {
          "type": "boolean"
        },
        "bulk_index_source": {
          "type": [
            "string",
            "null"
          ]
        },
        "per_record_query_required": {
          "type": "boolean"
        },
        "per_record_query_cost_estimate": {
          "type": "string"
        },
        "recommended_strategy": {
          "type": "string"
        },
        "deferred_to_version": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
